# Database connection string
DATABASE_URL=mongodb+srv:<>
# Or use a PG connection string
#DATABASE_URL=postgresql://127.0.0.1:5432/your-database-name
# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE
# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE
# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE
# Added by Payload


SUPABASE_BUCKET=BucketName
SUPABASE_ACCESS_KEY_ID=YOUR_SUPABASE_ACCESS_KEY_ID
SUPABASE_SECRET_ACCESS_KEY=YOUR_SUPABASE_SECRET_ACCESS_KEY
SUPABASE_ENDPOINT=YOUR_SUPABASE_ENDPOINT
SUPABASE_REGION=YOUR_SUPABASE_REGION

# Agent service account credentials (fill in with real values)
AGENT_EMAIL=agent@payload-poc.local
AGENT_PASSWORD=YOUR_AGENT_PASSWORD

# DeepSeek API key (fill in with real value)
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY

# CleanTalk anti-spam API key (server-only, never expose to client)
CLEANTALK_API_KEY=YOUR_CLEANTALK_API_KEY

# SMTP2GO email delivery (server-only)
SMTP2GO_HOST=mail.smtp2go.com
SMTP2GO_PORT=2525
SMTP2GO_USERNAME=YOUR_SMTP2GO_USERNAME
SMTP2GO_PASSWORD=YOUR_SMTP2GO_PASSWORD
SMTP2GO_FROM_EMAIL=no-reply@h6app.site